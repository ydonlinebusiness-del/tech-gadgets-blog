---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-logo" aria-label={`${SITE_TITLE} - Home`}>
			<span class="logo-icon">⚡</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">All Reviews</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1.5em;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid #e8ecf0;
		box-shadow: 0 1px 4px rgba(0,0,0,0.04);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1000px;
		margin: 0 auto;
		height: 60px;
	}
	.site-logo {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		text-decoration: none;
		color: #0f1219;
		font-weight: 800;
		font-size: 1.15rem;
	}
	.logo-icon {
		font-size: 1.3rem;
	}
	.logo-text {
		letter-spacing: -0.02em;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.nav-links :global(a) {
		padding: 0.4em 0.75em;
		color: #444;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		border-radius: 6px;
		border-bottom: none;
		transition: background 0.15s, color 0.15s;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		background: #f0f4ff;
		color: #2337ff;
	}
	@media (max-width: 480px) {
		.nav-links :global(a) {
			padding: 0.4em 0.4em;
			font-size: 0.82rem;
		}
	}
</style>
