---
const today = new Date();
---

<footer class="bg-[#0f1219] text-[#9aa5c2] px-6 pt-12 pb-8 mt-16">
	<div class="max-w-[1000px] mx-auto mb-8 flex justify-between items-start gap-8 flex-wrap">
		<div>
			<span class="text-[1.2rem] font-extrabold text-white">⚡ TechPickr</span>
			<p class="mt-1.5 text-[0.85rem] text-[#606f9f] m-0">Honest tech reviews to help you spend smarter.</p>
		</div>
		<div class="flex gap-6 flex-wrap items-center">
			<a href="/blog" class="text-[#9aa5c2] no-underline text-[0.88rem] hover:text-white transition-colors duration-150">All Reviews</a>
			<a href="/about" class="text-[#9aa5c2] no-underline text-[0.88rem] hover:text-white transition-colors duration-150">About</a>
			<a href="/about#affiliate" class="text-[#9aa5c2] no-underline text-[0.88rem] hover:text-white transition-colors duration-150">Affiliate Disclosure</a>
			<a href="/rss.xml" class="text-[#9aa5c2] no-underline text-[0.88rem] hover:text-white transition-colors duration-150">RSS Feed</a>
		</div>
		<div class="flex gap-6 flex-wrap items-center">
			<a href="/impressum" class="text-[#606f9f] no-underline text-[0.82rem] hover:text-white transition-colors duration-150">Impressum</a>
			<a href="/datenschutz" class="text-[#606f9f] no-underline text-[0.82rem] hover:text-white transition-colors duration-150">Datenschutz</a>
		</div>
	</div>

	<div class="max-w-[1000px] mx-auto mb-6 border-t border-[#1e2436] pt-6 text-[0.78rem] text-[#606f9f] leading-relaxed">
		<p class="m-0">
			<strong class="text-[#9aa5c2]">Affiliate Disclosure:</strong> TechPickr participates in the Amazon Associates program and other affiliate programs.
			When you purchase through links on this site, we may earn a small commission at no additional cost to you.
			This helps us keep the site running. We only recommend products we genuinely believe in.
		</p>
	</div>

	<div class="max-w-[1000px] mx-auto text-[0.78rem] text-[#454f6b]">
		&copy; {today.getFullYear()} TechPickr. All rights reserved.
	</div>
</footer>
