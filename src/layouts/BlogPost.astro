---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

type Props = CollectionEntry<'blog'>['data'] & { url: string };

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	category,
	affiliateDisclaimer,
	productName,
	productBrand,
	productPriceRange,
	url,
} = Astro.props;

const canonicalUrl = url ?? Astro.url.toString();
const schemaType = productName ? 'review' : 'article';
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | TechPickr`} description={description} />
		<SchemaMarkup
			type={schemaType}
			title={title}
			description={description}
			url={canonicalUrl}
			datePublished={pubDate.toISOString()}
			dateModified={(updatedDate ?? pubDate).toISOString()}
			productName={productName}
			productBrand={productBrand}
			priceRange={productPriceRange}
		/>
	</head>

	<body>
		<Header />
		<main>
			<article itemscope itemtype="https://schema.org/Article">

				{heroImage && (
					<div class="hero-image">
						<Image
							width={1020}
							height={510}
							src={heroImage}
							alt={title}
							loading="eager"
							itemprop="image"
						/>
					</div>
				)}

				<div class="prose">
					<!-- Breadcrumb-style meta -->
					<div class="meta-top">
						{category && <span class="category-badge">{category}</span>}
						{tags.slice(0, 3).map((tag) => (
							<span class="tag">#{tag}</span>
						))}
					</div>

					<!-- Dates -->
					<div class="date-row" itemprop="datePublished" content={pubDate.toISOString()}>
						<span class="date-icon">📅</span>
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated" itemprop="dateModified" content={updatedDate.toISOString()}>
								· Updated <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>

					<!-- Title -->
					<h1 itemprop="headline">{title}</h1>

					<!-- Affiliate disclaimer -->
					{affiliateDisclaimer !== false && (
						<div class="affiliate-disclaimer" role="note" aria-label="Affiliate disclosure">
							<span class="disclaimer-icon">💡</span>
							<span>
								<strong>Affiliate Disclosure:</strong> This post contains affiliate links.
								If you buy through our links, we may earn a small commission at no extra cost to you.
								We only recommend products we genuinely believe in.
								<a href="/about#affiliate">Learn more</a>.
							</span>
						</div>
					)}

					<hr />

					<!-- Article body -->
					<div class="article-body" itemprop="articleBody">
						<slot />
					</div>

					<!-- Tags footer -->
					{tags.length > 0 && (
						<div class="article-footer">
							<strong class="tags-label">Tags:</strong>
							<div class="tags-list">
								{tags.map((tag) => <span class="tag-pill">#{tag}</span>)}
							</div>
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2em 1.5em 5em;
	}

	.hero-image {
		margin-bottom: 2rem;
	}
	.hero-image img {
		width: 100%;
		height: auto;
		border-radius: 16px;
		box-shadow: 0 4px 24px rgba(0,0,0,0.1);
	}

	.prose {
		color: #1e293b;
	}

	/* Meta top */
	.meta-top {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-bottom: 0.6rem;
	}
	.category-badge {
		background: #f97316;
		color: white;
		padding: 0.2rem 0.75rem;
		border-radius: 100px;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
	}
	.tag {
		color: #94a3b8;
		font-size: 0.78rem;
	}

	/* Date */
	.date-row {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		color: #64748b;
		font-size: 0.85rem;
		margin-bottom: 0.75rem;
	}
	.date-icon { font-size: 0.9rem; }
	.updated {
		font-style: italic;
		color: #94a3b8;
	}

	/* Title */
	h1 {
		font-size: 2.25rem;
		line-height: 1.2;
		color: #0f172a;
		font-weight: 800;
		margin: 0 0 1.25rem;
		letter-spacing: -0.03em;
	}

	/* Disclaimer */
	.affiliate-disclaimer {
		display: flex;
		gap: 0.6rem;
		align-items: flex-start;
		background: #fff7ed;
		border: 1px solid #fed7aa;
		border-left: 4px solid #f97316;
		border-radius: 10px;
		padding: 0.85rem 1rem;
		font-size: 0.82rem;
		color: #7c3f00;
		line-height: 1.55;
		margin-bottom: 1.5rem;
	}
	.disclaimer-icon { flex-shrink: 0; margin-top: 0.05rem; }
	.affiliate-disclaimer a { color: #f97316; }
	.affiliate-disclaimer strong { color: #c2540a; }

	hr {
		border: none;
		border-top: 2px solid #f1f5f9;
		margin: 1.5rem 0 2rem;
	}

	/* Article body — scoped styles for markdown content */
	.article-body :global(h2) {
		font-size: 1.5rem;
		font-weight: 800;
		color: #0f172a;
		margin-top: 2.5rem;
		margin-bottom: 0.75rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid #f1f5f9;
	}
	.article-body :global(h3) {
		font-size: 1.2rem;
		font-weight: 700;
		color: #0f172a;
		margin-top: 1.75rem;
		margin-bottom: 0.5rem;
	}
	.article-body :global(p) {
		margin-bottom: 1.3em;
		line-height: 1.8;
		color: #334155;
	}
	.article-body :global(ul), .article-body :global(ol) {
		padding-left: 1.5em;
		margin-bottom: 1.3em;
	}
	.article-body :global(li) {
		margin-bottom: 0.35em;
		color: #334155;
	}
	.article-body :global(strong) {
		color: #0f172a;
		font-weight: 700;
	}

	/* Amazon CTA links */
	.article-body :global(a[href*="amazon.com"]) {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: #f97316;
		color: white !important;
		padding: 0.55rem 1.1rem;
		border-radius: 8px;
		font-weight: 700;
		font-size: 0.88rem;
		text-decoration: none !important;
		margin: 0.75rem 0;
		transition: background 0.2s, transform 0.15s;
		box-shadow: 0 2px 6px rgba(249,115,22,0.3);
	}
	.article-body :global(a[href*="amazon.com"]:hover) {
		background: #c2540a;
		transform: translateY(-1px);
		color: white !important;
	}

	/* Article footer */
	.article-footer {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid #e2e8f0;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.tags-label {
		font-size: 0.82rem;
		color: #64748b;
	}
	.tags-list {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.tag-pill {
		background: #f1f5f9;
		color: #475569;
		padding: 0.2rem 0.6rem;
		border-radius: 100px;
		font-size: 0.75rem;
		border: 1px solid #e2e8f0;
	}

	/* Responsive */
	@media (max-width: 640px) {
		main { padding: 1em 1em 4em; }
		h1 { font-size: 1.7rem; }
		.article-body :global(h2) { font-size: 1.25rem; }
	}
</style>
