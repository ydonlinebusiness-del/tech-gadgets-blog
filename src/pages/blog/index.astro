---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryColors: Record<string, string> = {
	'Buying Guide': 'linear-gradient(135deg, #f97316 0%, #fb923c 100%)',
	'Review': 'linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%)',
	'Comparison': 'linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%)',
	'Tips & Tricks': 'linear-gradient(135deg, #10b981 0%, #34d399 100%)',
};
const defaultGradient = 'linear-gradient(135deg, #f97316 0%, #fb923c 100%)';

const categories = ['All', ...new Set(posts.map(p => p.data.category).filter(Boolean))];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="All Reviews & Buying Guides | TechPickr" description="Browse all tech reviews, comparisons and buying guides — headphones, laptops, monitors, cameras and more." />
	</head>
	<body>
		<Header />
		<main class="max-w-[1080px] mx-auto px-6 py-12 pb-20">

			<!-- Page header -->
			<div class="mb-10">
				<p class="text-xs font-bold uppercase tracking-[0.12em] text-[#f97316] pl-3 border-l-[3px] border-[#f97316] mb-3">All Guides</p>
				<h1 class="text-3xl font-extrabold text-[#0f172a] tracking-tight mb-2">Reviews & Buying Guides</h1>
				<p class="text-[#64748b] text-sm">{posts.length} guides — updated weekly</p>
			</div>

			<!-- Category filter pills -->
			<div class="flex gap-2 flex-wrap mb-8">
				{categories.map((cat) => (
					<span class="px-3 py-1 rounded-full text-xs font-600 border border-[#e2e8f0] text-[#475569] bg-white cursor-pointer hover:border-[#f97316] hover:text-[#f97316] transition-colors">
						{cat}
					</span>
				))}
			</div>

			<!-- Article grid -->
			<ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 list-none p-0 m-0">
				{posts.map((post) => (
					<li class="group bg-white border border-[#e2e8f0] rounded-2xl overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.12)] hover:border-[#f97316] shadow-[0_1px_3px_rgba(0,0,0,0.05),0_2px_8px_rgba(0,0,0,0.04)] cursor-pointer">
						<a href={`/blog/${post.id}/`} class="flex flex-col h-full no-underline text-inherit">
							<!-- Thumbnail -->
							{post.data.heroImage ? (
								<img
									src={post.data.heroImage.src}
									alt={post.data.title}
									class="w-full h-44 object-cover"
									loading="lazy"
								/>
							) : (
								<div
									class="w-full h-44 flex flex-col items-center justify-center gap-2"
									style={`background: ${categoryColors[post.data.category ?? ''] ?? defaultGradient}`}
								>
									<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1.5" aria-hidden="true">
										<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
									</svg>
									<span class="text-white/70 text-[10px] font-bold uppercase tracking-widest">{post.data.category ?? 'Guide'}</span>
								</div>
							)}

							<!-- Card body -->
							<div class="p-4 flex flex-col flex-1 gap-1.5">
								<h2 class="text-[0.95rem] font-bold text-[#0f172a] leading-snug m-0 line-clamp-2">
									{post.data.title}
								</h2>
								<p class="text-[0.78rem] text-[#64748b] leading-relaxed m-0 flex-1 line-clamp-2">
									{post.data.description}
								</p>
								<div class="flex items-center justify-between mt-2 pt-2 border-t border-[#f1f5f9]">
									<time class="text-[0.72rem] text-[#94a3b8]">
										<FormattedDate date={post.data.pubDate} />
									</time>
									<span class="text-[0.78rem] text-[#f97316] font-semibold opacity-0 group-hover:opacity-100 transition-opacity">
										Read →
									</span>
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
