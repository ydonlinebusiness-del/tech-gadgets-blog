---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Get all blog posts, sorted newest first
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts.slice(0, 1)[0];
const recentPosts = posts.slice(1, 7);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero section -->
			<section class="hero-section">
				<h1 class="hero-title">Find the Best Tech for Your Budget</h1>
				<p class="hero-subtitle">
					Honest reviews, head-to-head comparisons, and curated buying guides — so you spend less time researching and more time enjoying great gadgets.
				</p>
			</section>

			<!-- Featured post -->
			{featured && (
				<section class="featured-section">
					<h2 class="section-label">✨ Featured</h2>
					<a href={`/blog/${featured.id}`} class="featured-card">
						{featured.data.heroImage && (
							<img
								src={featured.data.heroImage.src}
								alt={featured.data.title}
								class="featured-img"
								loading="eager"
								width="1020"
								height="510"
							/>
						)}
						<div class="featured-body">
							{featured.data.category && (
								<span class="category-badge">{featured.data.category}</span>
							)}
							<h3 class="featured-title">{featured.data.title}</h3>
							<p class="featured-desc">{featured.data.description}</p>
							<span class="featured-date">
								<FormattedDate date={featured.data.pubDate} />
							</span>
						</div>
					</a>
				</section>
			)}

			<!-- Recent posts grid -->
			{recentPosts.length > 0 && (
				<section class="posts-section">
					<h2 class="section-label">📰 Latest Reviews & Guides</h2>
					<ul class="post-grid">
						{recentPosts.map((post) => (
							<li class="post-card">
								<a href={`/blog/${post.id}`} class="post-card-link">
									{post.data.heroImage && (
										<img
											src={post.data.heroImage.src}
											alt={post.data.title}
											class="post-thumb"
											loading="lazy"
											width="400"
											height="225"
										/>
									)}
									<div class="post-card-body">
										{post.data.category && (
											<span class="category-tag">{post.data.category}</span>
										)}
										<h3 class="post-title">{post.data.title}</h3>
										<p class="post-desc">{post.data.description}</p>
										<time class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</time>
									</div>
								</a>
							</li>
						))}
					</ul>
				</section>
			)}

			<!-- All posts link -->
			<div class="view-all">
				<a href="/blog" class="view-all-link">View all articles →</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 2em 1em 4em;
	}

	/* Hero */
	.hero-section {
		text-align: center;
		padding: 2.5rem 1rem 3rem;
		max-width: 680px;
		margin: 0 auto;
	}
	.hero-title {
		font-size: 2.6rem;
		line-height: 1.15;
		margin-bottom: 1rem;
		color: #0f1219;
	}
	.hero-subtitle {
		font-size: 1.1rem;
		color: #606f9f;
		line-height: 1.6;
		margin: 0;
	}

	/* Section labels */
	.section-label {
		font-size: 1rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #606f9f;
		margin-bottom: 1rem;
	}

	/* Featured card */
	.featured-section {
		margin-bottom: 3rem;
	}
	.featured-card {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		border: 1px solid #e8ecf0;
		border-radius: 14px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: box-shadow 0.2s;
	}
	.featured-card:hover {
		box-shadow: 0 4px 20px rgba(0,0,0,0.1);
	}
	.featured-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.featured-body {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.category-badge {
		display: inline-block;
		background: #2337ff;
		color: white;
		padding: 0.2rem 0.7rem;
		border-radius: 20px;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.75rem;
		align-self: flex-start;
	}
	.featured-title {
		font-size: 1.6rem;
		margin: 0 0 0.75rem;
		line-height: 1.25;
	}
	.featured-desc {
		color: #606f9f;
		font-size: 0.95rem;
		flex: 1;
	}
	.featured-date {
		color: #aaa;
		font-size: 0.8rem;
		margin-top: 1rem;
	}

	/* Post grid */
	.posts-section {
		margin-bottom: 2rem;
	}
	.post-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.post-card {
		border: 1px solid #e8ecf0;
		border-radius: 12px;
		overflow: hidden;
		transition: box-shadow 0.2s, transform 0.15s;
	}
	.post-card:hover {
		box-shadow: 0 4px 16px rgba(0,0,0,0.09);
		transform: translateY(-2px);
	}
	.post-card-link {
		display: block;
		text-decoration: none;
		color: inherit;
		height: 100%;
	}
	.post-thumb {
		width: 100%;
		height: 170px;
		object-fit: cover;
		display: block;
	}
	.post-card-body {
		padding: 1rem;
	}
	.category-tag {
		font-size: 0.7rem;
		font-weight: 700;
		color: #2337ff;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.post-title {
		font-size: 1rem;
		margin: 0.35rem 0 0.5rem;
		line-height: 1.3;
	}
	.post-desc {
		font-size: 0.82rem;
		color: #606f9f;
		margin: 0 0 0.75rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.post-date {
		font-size: 0.75rem;
		color: #bbb;
	}

	/* View all */
	.view-all {
		text-align: center;
		margin-top: 2rem;
	}
	.view-all-link {
		display: inline-block;
		border: 2px solid #2337ff;
		color: #2337ff;
		padding: 0.6rem 1.5rem;
		border-radius: 8px;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.2s, color 0.2s;
	}
	.view-all-link:hover {
		background: #2337ff;
		color: white;
	}

	/* Responsive */
	@media (max-width: 720px) {
		.featured-card {
			grid-template-columns: 1fr;
		}
		.featured-img {
			height: 220px;
		}
		.post-grid {
			grid-template-columns: 1fr 1fr;
		}
		.hero-title {
			font-size: 1.9rem;
		}
	}
	@media (max-width: 480px) {
		.post-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
